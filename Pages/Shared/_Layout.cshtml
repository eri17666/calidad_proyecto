<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VitalCare</title>

    <link rel="icon" type="image/x-icon" href="~/favicon.ico?v=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VitalCare.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/medicamento-form.css" asp-append-version="true" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-success fixed-top shadow">
            <div class="container">

                <a class="navbar-brand d-flex align-items-center" asp-page="/Index">
                    <img src="~/images/vitalcare.png" height="40" class="me-2" />
                    VitalCare
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarVitalCare">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarVitalCare">

                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">Inicio</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Privacy">Privacidad</a>
                        </li>

                        @{
                            var usuario = Context.Session.GetString("Usuario");
                        }

                        @if (usuario != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="medicamentosDropdown" role="button">
                                    Medicamentos
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-page="/Medicamento/Medicamento">
                                            Gestionar Medicamentos
                                        </a>
                                    </li>
                                  
                                </ul>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="ventasDropdown" role="button">
                                    Ventas
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-page="/Cliente/Cliente">
                                            Gestionar Clientes
                                        </a>
                                    </li>
                                    
                                </ul>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="bioquimicosDropdown" role="button">
                                    Bioquímicos
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-page="/Bioquimico/Bioquimico">
                                            Gestionar Bioquímicos
                                        </a>
                                    </li>
                                    
                                </ul>
                            </li>



                            <li class="nav-item">
                                <a class="nav-link text-warning"
                                   asp-page="/Auth/Logout">
                                    Cerrar Sesión
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-page="/Auth/Login">
                                    Login
                                </a>
                            </li>
                        }

                    </ul>

                </div>

            </div>
        </nav>
    </header>


    @RenderBody()


    <!-- FOOTER -->
    <footer class="footer mt-5">
        <div class="container">
            <div class="row">

                <div class="col-md-3">
                    <h5>Síguenos</h5>
                    <ul>
                        <li><a href="#">Facebook</a></li>
                        <li><a href="#">Instagram</a></li>
                        <li><a href="#">LinkedIn</a></li>
                    </ul>
                </div>

                <div class="col-md-3">
                    <h5>Atención</h5>
                    <ul>
                        <li><a href="#">Atención al cliente</a></li>
                        <li><a href="#">Preguntas frecuentes</a></li>
                        <li><a asp-page="/Privacy">Política de privacidad</a></li>
                    </ul>
                </div>

                <div class="col-md-3">
                    <h5>Servicios</h5>
                    <ul>
                        <li><a href="#">Servicios de salud</a></li>
                        <li><a href="#">Entrega a domicilio</a></li>
                        <li><a href="#">Ventas corporativas</a></li>
                    </ul>
                </div>

                <div class="col-md-3">
                    <h5>Contacto</h5>
                    <ul>
                        <li>Cochabamba, Bolivia</li>
                        <li>+591 77777777</li>
                        <li>contacto@vitalcare.com</li>
                    </ul>
                </div>

            </div>

            <hr />

            <div class="text-center">
                <p>
                    © 2026 Farmacia VitalCare - Sistema de Gestión Farmacéutica
                </p>
            </div>
        </div>
    </footer>


    <script>
        window.addEventListener("scroll", function(){
            let navbar = document.querySelector(".navbar");
            navbar.classList.toggle("scrolled", window.scrollY > 50);
        });
    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
