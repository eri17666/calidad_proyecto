@page

@model ProyectoArqSoft.Pages.BioquimicoModel

@{

    ViewData["Title"] = "Bioquímicos";

}



<div class="container mt-5">



    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold text-success">Bioquímicos Registrados</h2>



        <a asp-page="BioquimicoCreate" class="btn-main">

            + Nuevo Bioquímico

        </a>

    </div>



    <form method="get" class="mb-4">



        <div class="card-module p-3">



            <div class="input-group">



                <input type="text"

                       name="filtro"

                       class="form-control"

                       placeholder="Buscar por nombres, apellidos o CI..."

                       value="@Model.Filtro" />



                <button type="submit"

                        class="btn btn-success btn-fixed">

                    Buscar

                </button>



                <a asp-page="Bioquimico"

                   class="btn btn-secondary btn-fixed">

                    Limpiar

                </a>



            </div>



        </div>



    </form>



    @if (!string.IsNullOrEmpty(Model.Estado.Mensaje))

    {

        <div class="alert alert-success shadow-sm">@Model.Estado.Mensaje</div>

    }



    @if (!string.IsNullOrEmpty(Model.Estado.MensajeError))

    {

        <div class="alert alert-danger shadow-sm">@Model.Estado.MensajeError</div>

    }



    <div class="card-module">



        <table class="table table-hover align-middle">



            <thead class="table-success">

                <tr>

                    <th>Nombres</th>

                    <th>Apellido Paterno</th>

                    <th>Apellido Materno</th>

                    <th>Carnet</th>

                    <th>Expedido</th>

                    <th>Teléfono</th>

                    <th style="width:170px">Acciones</th>

                </tr>

            </thead>



            <tbody>



                @if (Model.dtBioquimicos != null && Model.dtBioquimicos.Rows.Count > 0)

                {

                    @foreach (System.Data.DataRow row in Model.dtBioquimicos.Rows)

                    {

                        <tr>

                            <td class="fw-semibold">@row["nombres"]</td>

                            <td>@row["apellido_paterno"]</td>

                            <td>@row["apellido_materno"]</td>

                            <td>@row["ci"]</td>

                            <td>

                                <span class="badge bg-info text-dark">

                                    @row["ci_extencion"]

                                </span>

                            </td>

                            <td>@row["telefono"]</td>

                            <td>

                                <form method="post"

                                      asp-page="BioquimicoEdit"

                                      asp-page-handler="CargarBioquimicoParaEdicion"

                                      style="display:inline;">



                                    <input type="hidden"

                                           name="id"

                                           value="@row["idBioquimico"]" />



                                    <button type="submit"

                                            class="btn btn-warning btn-sm">

                                        Editar

                                    </button>

                                </form>



                                <button type="button"

                                        class="btn btn-danger btn-sm btnEliminar"

                                        data-id="@row["idBioquimico"]"

                                        data-nombre="@row["nombres"] @row["apellido_paterno"]"

                                        data-bs-toggle="modal"

                                        data-bs-target="#modalEliminarBioquimico">

                                    Eliminar

                                </button>

                            </td>

                        </tr>

                    }

                }

                else

                {

                    <tr>

                        <td colspan="7" class="text-center py-4 text-muted">No se encontraron bioquímicos.</td>

                    </tr>

                }



            </tbody>



        </table>



    </div>



</div>



<div class="modal fade"

     id="modalEliminarBioquimico"

     tabindex="-1"

     aria-hidden="true">



    <div class="modal-dialog modal-dialog-centered">



        <div class="modal-content shadow">



            <div class="modal-header bg-success text-white">



                <h5 class="modal-title">

                    Confirmar eliminación

                </h5>



                <button type="button"

                        class="btn-close btn-close-white"

                        data-bs-dismiss="modal">

                </button>



            </div>



            <div class="modal-body">

                <p>¿Está seguro de que desea eliminar a este bioquímico?</p>

                <p class="fw-bold" id="nombreBioquimicoEliminar"></p>

            </div>



            <div class="modal-footer">



                <button type="button"

                        class="btn btn-secondary"

                        data-bs-dismiss="modal">

                    Cancelar

                </button>



                <form method="post" asp-page-handler="Eliminar">

                    <input type="hidden" id="idBioquimicoEliminar" name="id" />

                    <button type="submit" class="btn btn-danger">

                        Eliminar

                    </button>

                </form>



            </div>



        </div>



    </div>



</div>



@section Scripts {

    <script>

        document.addEventListener("DOMContentLoaded", function () {

            const botonesEliminar = document.querySelectorAll(".btnEliminar");



            botonesEliminar.forEach(boton => {

                boton.addEventListener("click", function () {

                    const id = this.getAttribute("data-id");

                    const nombre = this.getAttribute("data-nombre");



                    document.getElementById("idBioquimicoEliminar").value = id;

                    document.getElementById("nombreBioquimicoEliminar").textContent = nombre;

                });

            });

        });

    </script>

}