@page
@model ProyectoArqSoft.Pages.ClienteEditModel
@{
}

<div class="container py-5 medicamento-form-page">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <div class="med-card shadow-sm">
                <div class="med-card-header text-center">
                    <h2 class="mb-0">Actualizar Cliente</h2>
                    <p class="text-muted mt-2 mb-0">Modifica los datos del cliente seleccionado</p>
                </div>

                <div class="med-card-body">
                    <form method="post" asp-page-handler="ActualizarCliente">

                        <input type="hidden" asp-for="IdCliente" />

                        <div class="mb-4">
                            <label class="form-label fw-semibold d-block mb-3">Tipo de registro</label>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="border rounded-4 p-3 w-100 h-100 bg-white shadow-sm" for="tipoClienteFormal" style="cursor:pointer;">
                                        <input asp-for="EsConsumidorFinal"
                                               id="tipoClienteFormal"
                                               type="radio"
                                               value="false"
                                               class="form-check-input me-2" />
                                        <span class="fw-semibold d-block mb-1">Cliente con datos fiscales</span>
                                        <span class="text-muted small">Permite editar NIT, razón social y correo electrónico.</span>
                                    </label>
                                </div>

                                <div class="col-md-6">
                                    <label class="border rounded-4 p-3 w-100 h-100 bg-light shadow-sm" for="tipoConsumidorFinal" style="cursor:pointer;">
                                        <input asp-for="EsConsumidorFinal"
                                               id="tipoConsumidorFinal"
                                               type="radio"
                                               value="true"
                                               class="form-check-input me-2" />
                                        <span class="fw-semibold d-block mb-1">Consumidor Final</span>
                                        <span class="text-muted small">El sistema guardara automaticamente NIT = CF y razón social = Consumidor Final.</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div id="bloqueConsumidorFinal" class="alert alert-success border-0 shadow-sm mb-4" style="display:none;">
                            Este cliente se guardara como <strong>Consumidor Final</strong>. No necesitas ingresar NIT, razón social ni correo electrónico.
                        </div>

                        <div id="datosClienteFiscal">
                            <div class="form-floating mb-3">
                                <input asp-for="Nit"
                                       class="form-control med-input"
                                       placeholder="NIT"
                                       inputmode="numeric"
                                       maxlength="20"
                                       pattern="[0-9]{5,20}"
                                       title="Formato valido: 123456789"
                                       required />
                                <label asp-for="Nit"></label>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="RazonSocial"
                                       class="form-control med-input"
                                       placeholder="Razon Social"
                                       minlength="3"
                                       maxlength="45"
                                       title="Formato valido: minimo 3 caracteres"
                                       required />
                                <label asp-for="RazonSocial"></label>
                            </div>

                            <div id="correoElectronicoGroup" class="form-floating mb-3">
                                <input asp-for="CorreoElectronico"
                                       type="email"
                                       class="form-control med-input"
                                       placeholder="Correo Electronico"
                                       maxlength="45"
                                       title="Formato valido: ejemplo@correo.com" />
                                <label asp-for="CorreoElectronico"></label>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Estado.MensajeError))
                        {
                            <div class="alert alert-danger med-alert" role="alert">
                                @Model.Estado.MensajeError
                            </div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-page="Cliente" class="btn med-btn-secondary">Volver</a>
                            <button type="submit" class="btn med-btn-primary">Actualizar</button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const opcionFormal = document.getElementById('tipoClienteFormal');
            const opcionConsumidorFinal = document.getElementById('tipoConsumidorFinal');
            const bloqueInformativo = document.getElementById('bloqueConsumidorFinal');
            const contenedor = document.getElementById('datosClienteFiscal');
            const correoGroup = document.getElementById('correoElectronicoGroup');
            const nit = document.getElementById('Nit');
            const razonSocial = document.getElementById('RazonSocial');
            const correo = document.getElementById('CorreoElectronico');

            if (!opcionFormal.checked && !opcionConsumidorFinal.checked) {
                opcionFormal.checked = true;
            }

            const actualizarFormulario = () => {
                const esConsumidorFinal = opcionConsumidorFinal.checked;

                bloqueInformativo.style.display = esConsumidorFinal ? '' : 'none';
                contenedor.style.display = esConsumidorFinal ? 'none' : '';
                correoGroup.style.display = esConsumidorFinal ? 'none' : '';

                nit.required = !esConsumidorFinal;
                razonSocial.required = !esConsumidorFinal;

                if (esConsumidorFinal) {
                    nit.value = '';
                    razonSocial.value = '';
                    correo.value = '';
                }
            };

            actualizarFormulario();
            opcionFormal.addEventListener('change', actualizarFormulario);
            opcionConsumidorFinal.addEventListener('change', actualizarFormulario);
        })();
    </script>
}
