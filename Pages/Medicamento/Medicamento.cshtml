@page
@model ProyectoArqSoft.Pages.MedicamentoModel
@{
}

<div class="container mt-5">

    <!-- TITULO -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">Medicamentos en Stock</h2>

        <a asp-page="MedicamentoCreate" class="btn-main">
            + Nuevo Medicamento
        </a>
    </div>

    <!-- BUSCADOR -->
    <form method="get" class="mb-4">

        <div class="card-module p-3">

            <div class="input-group">

                <input type="text"
                       name="filtro"
                       class="form-control"
                       placeholder="Buscar por nombre, clasificación o presentación..."
                       value="@Model.Estado.FiltroActual" />

                <button type="submit"
                        class="btn btn-success btn-fixed">
                    Buscar
                </button>

                <a asp-page="Medicamento"
                   class="btn btn-secondary btn-fixed">
                    Limpiar
                </a>

            </div>

        </div>

    </form>

    <!-- MENSAJES -->
    @if (!string.IsNullOrEmpty(Model.Estado.Mensaje))
    {
        <div class="alert alert-success shadow-sm">@Model.Estado.Mensaje</div>
    }

    @if (!string.IsNullOrEmpty(Model.Estado.MensajeError))
    {
        <div class="alert alert-danger shadow-sm">@Model.Estado.MensajeError</div>
    }

    <!-- TABLA -->
    <div class="card-module">

        <table class="table table-hover align-middle">

            <thead class="table-success">
                <tr>
                    <th>Nombre</th>
                    <th>Presentación</th>
                    <th>Clasificación</th>
                    <th>Concentración</th>
                    <th>Precio (Bs)</th>
                    <th style="width:170px">Acciones</th>
                </tr>
            </thead>

            <tbody>

                @foreach (System.Data.DataRow row in Model.MedicamentoDataTable.Rows)
                {
                    <tr>

                        <td class="fw-semibold">@row["nombre"]</td>

                        <td>@row["presentacion"]</td>

                        <td>
                            <span class="badge bg-info text-dark">
                                @row["clasificacion"]
                            </span>
                        </td>

                        <td>@row["concentracion"]</td>

                        <td class="text-success fw-bold">
                             @row["precio"]
                        </td>

                        <td>

                            <!-- EDITAR -->
                            <form method="post"
                                  asp-page="MedicamentoUpdate"
                                  asp-page-handler="CargarMedicamentoParaEdicion"
                                  style="display:inline;">

                                <input type="hidden"
                                       name="id"
                                       value="@row["id_medicamento"]" />

                                <button type="submit"
                                        class="btn btn-warning btn-sm">
                                    Editar
                                </button>

                            </form>

                            <!-- BOTON ELIMINAR (abre modal) -->
                            <button type="button"
                                    class="btn btn-danger btn-sm btnEliminar"
                                    data-id="@row["id_medicamento"]"
                                    data-nombre="@row["nombre"]"
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalEliminarMedicamento">
                                Eliminar
                            </button>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

<!-- MODAL CONFIRMAR ELIMINACION -->

<div class="modal fade"
     id="modalEliminarMedicamento"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content shadow">

            <div class="modal-header bg-success text-white">

                <h5 class="modal-title">
                    Confirmar eliminación
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <p>¿Está seguro de que desea eliminar este medicamento?</p>

                <p class="fw-bold" id="nombreMedicamentoEliminar"></p>

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <form method="post"
                      asp-page-handler="EliminarMedicamentoLogicamente">

                    <input type="hidden"
                           id="idMedicamentoEliminar"
                           name="id" />

                    <button type="submit"
                            class="btn btn-danger">
                        Eliminar
                    </button>

                </form>

            </div>

        </div>

    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const botonesEliminar = document.querySelectorAll(".btnEliminar");

        botonesEliminar.forEach(boton => {
            boton.addEventListener("click", function () {
                const id = this.getAttribute("data-id");
                const nombre = this.getAttribute("data-nombre");

                document.getElementById("idMedicamentoEliminar").value = id;
                document.getElementById("nombreMedicamentoEliminar").textContent = nombre;
            });
        });
    });
</script>